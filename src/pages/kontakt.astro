---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import kontakty from '../data/kontakty.json';

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	name: kontakty.firma.nazev,
	email: kontakty.email,
	telephone: kontakty.osoby.map((o) => o.telefon),
	address: {
		'@type': 'PostalAddress',
		streetAddress: kontakty.adresa.ulice,
		postalCode: kontakty.adresa.psc,
		addressLocality: kontakty.adresa.mesto,
		addressCountry: 'CZ',
	},
	openingHours: 'Mo-Fr 07:00-16:00',
	url: 'https://kovovyrobarozbroj.cz',
	sameAs: [kontakty.socialni.instagram.url, kontakty.socialni.facebook.url],
};
---

<BaseLayout
	title="Kontakt | Kovovýroba Rozbroj Karviná"
	description={`Kontaktujte nás. Karviná, ${kontakty.adresa.ulice}. Telefon ${kontakty.osoby[0].telefon} (Tomáš) nebo ${kontakty.osoby[1].telefon} (Martin). E-mail ${kontakty.email}.`}
>
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

	<Hero title="Kontakt" />

	<section class="py-16 md:py-24">
		<div class="max-w-6xl mx-auto px-4 md:px-8 grid gap-8 md:grid-cols-2">
			<article class="bg-bg-darker/60 border border-white/10 rounded-lg p-6 md:p-8">
				<h2 class="font-serif text-2xl text-white mb-4">E-mail</h2>
				<a href={`mailto:${kontakty.email}`} class="text-accent-light hover:text-accent break-all">{kontakty.email}</a>
			</article>

			<article class="bg-bg-darker/60 border border-white/10 rounded-lg p-6 md:p-8">
				<h2 class="font-serif text-2xl text-white mb-4">Telefon</h2>
				<p class="text-gray-300 mb-3">Kontaktujte nás na číslech:</p>
				<ul class="space-y-2">
					{kontakty.osoby.map((osoba) => (
						<li>
							<span class="text-gray-300">{osoba.jmeno}: </span>
							<a href={osoba.telefonLink} class="text-accent-light hover:text-accent">{osoba.telefon}</a>
						</li>
					))}
				</ul>
			</article>

			<article class="bg-bg-darker/60 border border-white/10 rounded-lg p-6 md:p-8">
				<h2 class="font-serif text-2xl text-white mb-4">Navštivte nás</h2>
				<address class="not-italic text-gray-200 leading-relaxed">
					{kontakty.adresa.mesto}, {kontakty.adresa.ulice}<br />
					{kontakty.adresa.psc} {kontakty.adresa.mesto}
				</address>
			</article>

			<article class="bg-bg-darker/60 border border-white/10 rounded-lg p-6 md:p-8">
				<h2 class="font-serif text-2xl text-white mb-4">Otevírací doba</h2>
				<ul class="space-y-1 text-gray-200">
					{kontakty.oteviraciDoba.map((den) => (
						<li><span class="text-gray-400">{den.dny}:</span> {den.hodiny}</li>
					))}
				</ul>
			</article>

			<article class="bg-bg-darker/60 border border-white/10 rounded-lg p-6 md:p-8">
				<h2 class="font-serif text-2xl text-white mb-4">Instagram</h2>
				<a href={kontakty.socialni.instagram.url} target="_blank" rel="noopener noreferrer" class="text-accent-light hover:text-accent">{kontakty.socialni.instagram.handle}</a>
			</article>

			<article class="bg-bg-darker/60 border border-white/10 rounded-lg p-6 md:p-8">
				<h2 class="font-serif text-2xl text-white mb-4">Facebook</h2>
				<a href={kontakty.socialni.facebook.url} target="_blank" rel="noopener noreferrer" class="text-accent-light hover:text-accent">{kontakty.socialni.facebook.nazev}</a>
			</article>
		</div>
	</section>

	<section class="pb-16 md:pb-24">
		<div class="max-w-6xl mx-auto px-4 md:px-8">
			<iframe
				title="Mapa — Rudé Armády 1820/31, Karviná"
				src="https://www.google.com/maps?q=Rud%C3%A9+Arm%C3%A1dy+1820%2F31%2C+Karvin%C3%A1&output=embed"
				width="100%"
				height="400"
				style="border:0;"
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"
			></iframe>
		</div>
	</section>

	<section class="py-16 md:py-24 border-t border-white/10">
		<div class="max-w-4xl mx-auto px-4 md:px-8 text-center">
			<h2 class="font-serif text-3xl md:text-4xl text-white">Těšíme se na spolupráci!</h2>
			<div class="mt-4 mx-auto w-12 h-px bg-accent-light"></div>
			<div class="mt-10 grid gap-8 sm:grid-cols-2 text-left">
				{kontakty.osoby.map((osoba) => (
					<div class="bg-bg-darker/60 border border-white/10 rounded-lg p-6">
						<h3 class="font-serif text-xl text-white mb-3">{osoba.jmeno}</h3>
						<p class="text-gray-300">IČ: {osoba.ic}</p>
						<p class="text-gray-300">
							Tel: <a href={osoba.telefonLink} class="text-accent-light hover:text-accent">{osoba.telefon}</a>
						</p>
					</div>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
