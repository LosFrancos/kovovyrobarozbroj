---
import kontakty from '../data/kontakty.json';

interface GalleryItem {
	src: string;
	alt: string;
	kategorie?: string;
}

interface Props {
	items?: GalleryItem[];
}

const { items = [] } = Astro.props;
const hasItems = items.length > 0;
---

{hasItems ? (
	<div class="grid gap-3 sm:gap-4 grid-cols-2 md:grid-cols-3">
		{items.map((item) => (
			<figure class="overflow-hidden rounded bg-bg-darker">
				<img
					src={item.src}
					alt={item.alt}
					class="w-full h-56 md:h-64 object-cover hover:scale-105 transition-transform duration-500"
					loading="lazy"
					decoding="async"
				/>
				{item.kategorie && (
					<figcaption class="px-3 py-2 text-xs text-gray-400">{item.kategorie}</figcaption>
				)}
			</figure>
		))}
	</div>
) : (
	<div class="border border-white/10 rounded-lg bg-bg-darker/60 p-10 md:p-14 text-center">
		<p class="text-gray-200 text-lg leading-relaxed">
			Galerie se připravuje. Prohlédnout si naše realizace můžete také na našem{' '}
			<a
				href={kontakty.socialni.instagram.url}
				target="_blank"
				rel="noopener noreferrer"
				class="text-accent-light hover:text-accent underline underline-offset-4"
			>
				Instagramu
			</a>{' '}
			a{' '}
			<a
				href={kontakty.socialni.facebook.url}
				target="_blank"
				rel="noopener noreferrer"
				class="text-accent-light hover:text-accent underline underline-offset-4"
			>
				Facebooku
			</a>.
		</p>
	</div>
)}
