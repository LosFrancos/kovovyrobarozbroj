---
interface Props {
	title?: string;
	ctaLabel?: string;
	ctaHref?: string;
	image?: string;
	imageAlt?: string;
	imageSide?: 'left' | 'right';
	eyebrow?: string;
	tone?: 'default' | 'alt';
}

const {
	title,
	ctaLabel,
	ctaHref,
	image,
	imageAlt = '',
	imageSide = 'right',
	eyebrow,
	tone = 'default',
} = Astro.props;
---

<section
	class:list={[
		'py-16 md:py-24 border-t border-white/5',
		tone === 'alt' ? 'bg-bg-darker/50' : '',
	]}
>
	<div class="max-w-6xl mx-auto px-4 md:px-8">
		{image ? (
			<div
				class:list={[
					'grid gap-10 md:gap-14 items-center md:grid-cols-2',
					imageSide === 'left' ? 'md:[&>div:first-child]:order-1' : '',
				]}
			>
				<div>
					<img
						src={image}
						alt={imageAlt}
						class="w-full h-auto rounded shadow-lg"
						loading="lazy"
						decoding="async"
					/>
				</div>
				<div>
					{eyebrow && <p class="text-xs uppercase tracking-widest text-accent-light mb-3">{eyebrow}</p>}
					{title && (
						<h2 class="font-serif text-3xl md:text-4xl text-white leading-tight">
							{title}
							<span class="block mt-4 w-12 h-px bg-accent-light"></span>
						</h2>
					)}
					<div class="mt-6 text-gray-200 leading-relaxed space-y-4">
						<slot />
					</div>
					{ctaLabel && ctaHref && (
						<a
							href={ctaHref}
							class="inline-block mt-7 px-6 py-3 bg-accent hover:bg-accent-hover text-white font-medium rounded transition-colors"
						>
							{ctaLabel}
						</a>
					)}
				</div>
			</div>
		) : (
			<div class="max-w-3xl mx-auto text-center">
				{eyebrow && <p class="text-xs uppercase tracking-widest text-accent-light mb-3">{eyebrow}</p>}
				{title && (
					<h2 class="font-serif text-3xl md:text-4xl text-white leading-tight">
						{title}
						<span class="block mt-4 mx-auto w-12 h-px bg-accent-light"></span>
					</h2>
				)}
				<div class="mt-6 text-gray-200 leading-relaxed space-y-4">
					<slot />
				</div>
				{ctaLabel && ctaHref && (
					<a
						href={ctaHref}
						class="inline-block mt-7 px-6 py-3 bg-accent hover:bg-accent-hover text-white font-medium rounded transition-colors"
					>
						{ctaLabel}
					</a>
				)}
			</div>
		)}
	</div>
</section>
