---
import navigace from '../data/navigace.json';
import kontakty from '../data/kontakty.json';

const rok = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-bg-darker mt-24">
	<div class="max-w-6xl mx-auto px-4 md:px-8 py-12 grid gap-10 md:grid-cols-3">
		<div>
			<p class="font-serif text-xl text-accent-light">{kontakty.firma.nazev}</p>
			<p class="mt-3 text-sm text-gray-400 leading-relaxed">
				Rodinná kovovýroba z Karviné. Brány, ploty, schodiště, zábradlí a kovový nábytek na míru.
			</p>
			<p class="mt-3 text-xs text-gray-500">Působíme v ČR, na Slovensku a v Polsku.</p>
		</div>

		<nav aria-label="Patička – navigace">
			<p class="text-xs uppercase tracking-wider text-gray-500 mb-3">Rychlé odkazy</p>
			<ul class="space-y-2">
				{navigace.map((item) => (
					<li>
						<a href={item.url} class="text-gray-300 hover:text-accent-light transition-colors">
							{item.nazev}
						</a>
					</li>
				))}
			</ul>
		</nav>

		<div>
			<p class="text-xs uppercase tracking-wider text-gray-500 mb-3">Kontakt</p>
			<ul class="space-y-2 text-gray-300">
				<li>
					<a href={`mailto:${kontakty.email}`} class="hover:text-accent-light transition-colors">
						{kontakty.email}
					</a>
				</li>
				{kontakty.osoby.map((osoba) => (
					<li>
						<span class="text-gray-400">{osoba.jmeno.split(' ')[0]}:</span>{' '}
						<a href={osoba.telefonLink} class="hover:text-accent-light transition-colors">
							{osoba.telefon}
						</a>
					</li>
				))}
			</ul>

			<div class="mt-5 flex items-center gap-3">
				<a
					href={kontakty.socialni.instagram.url}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Instagram"
					class="text-gray-400 hover:text-accent-light transition-colors"
				>
					<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
						<rect x="3" y="3" width="18" height="18" rx="5" />
						<circle cx="12" cy="12" r="4" />
						<circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
					</svg>
				</a>
				<a
					href={kontakty.socialni.facebook.url}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Facebook"
					class="text-gray-400 hover:text-accent-light transition-colors"
				>
					<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M13.5 21v-7.5h2.5l.4-3h-2.9V8.6c0-.9.2-1.5 1.5-1.5h1.6V4.4c-.3 0-1.2-.1-2.3-.1-2.3 0-3.8 1.4-3.8 3.9v2.2H8v3h2.5V21h3z" />
					</svg>
				</a>
			</div>
		</div>
	</div>

	<div class="border-t border-white/5">
		<div class="max-w-6xl mx-auto px-4 md:px-8 py-5 text-xs text-gray-500 flex flex-wrap gap-2 justify-between">
			<span>© {rok} {kontakty.firma.nazev}</span>
			<span>
				{kontakty.osoby[0].jmeno} (IČ {kontakty.osoby[0].ic}) &middot;
				{kontakty.osoby[1].jmeno} (IČ {kontakty.osoby[1].ic})
			</span>
		</div>
	</div>
</footer>
